# ============= LLM 配置 =============
# OpenAI Provider 配置（預設）
OPENAI_BASE_URL=http://116.50.47.234:8081/v1
OPENAI_API_KEY=your-api-key-here
OPENAI_MODEL=Qwen/Qwen3.5-397B-A17B-FP8

# Ubisage Provider 配置（選用）
# 取消註解以使用 Ubisage Provider
# LLM_PROVIDER=ubisage
# UBISAGE_API_KEY=your-ubisage-token
# UBISAGE_GRANT_URL=https://sage-stg.ubitus.ai/ubillm/api/v1/resource/grant
# UBISAGE_MODEL=qwen3-8b-fp8

# ============= KNOWLEDGE 配置（選用）=============
# 知識庫基礎路徑（Docker 內）
KNOWLEDGE_BASE_PATH=/knowledge

# 通關密語（用於 KNOWLEDGE 管理 Tool）
# 預設：5688，建議修改為自訂值
KNOWLEDGE_PASSPHRASE=5688

# ============= 其他配置（選用）=============

# 串流配置
STREAM_MIN_CHARS=800
STREAM_MAX_CHARS=1200

# 最大並行 Tool 執行數
MAX_PARALLEL_TOOLS=5

# ============================================
# 性能監控配置 (可選)
# ============================================

# 啟用計時分析 (true | false)
# 如果為 true，回應中會包含 timings 數據
ENABLE_TIMING=true

# 啟用 Token Usage 統計 (true | false)
# 如果為 true，回應中會包含 usage 數據
ENABLE_TOKEN_USAGE=true

# ============================================
# LLM 進階配置 (可選)
# ============================================

# 思考模式 (disabled | enabled)
# disabled: 關閉 thinking 模式，加快回應速度
THINKING=disabled

# Reasoning 努力程度 (low | medium | high)
REASONING_EFFORT=low
