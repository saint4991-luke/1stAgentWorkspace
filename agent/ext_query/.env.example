# =============================================================================
# ext_query 模組配置 - 電話號碼資料庫查詢服務
# =============================================================================
# 複製此檔案為 .env 並填入實際的 API Key
# cp .env.example .env

# -----------------------------------------------------------------------------
# uBillm LLM API 配置 (用於意圖解析)
# -----------------------------------------------------------------------------
UBILM_GRANT_URL=https://sage-stg.ubitus.ai/ubillm/api/v1/resource/grant
UBILM_API_KEY=YOUR_UBILM_API_KEY_HERE
UBILM_LLM_MODEL=qwen3-8b-fp8

# -----------------------------------------------------------------------------
# uBillm Embedding API 配置 (用於向量嵌入)
# -----------------------------------------------------------------------------
UBILM_EMBED_MODEL=qwen3-embedding-4b

# -----------------------------------------------------------------------------
# Qdrant 向量資料庫配置
# -----------------------------------------------------------------------------
QDRANT_HOST=140.227.187.126
QDRANT_PORT=6334
QDRANT_COLLECTION=default_kb_832887850831363957

# -----------------------------------------------------------------------------
# uBigPT LLM API 配置 (用於最終回答生成)
# -----------------------------------------------------------------------------
UBIGPT_FQDN=https://g.ubitus.ai/v1/chat/completions
UBIGPT_AUTH_KEY=Bearer YOUR_UBIGPT_AUTH_KEY_HERE
UBIGPT_MODEL=llama-4-maverick-fp8

# -----------------------------------------------------------------------------
# 日誌配置
# -----------------------------------------------------------------------------
LOG_PATH=logs

# -----------------------------------------------------------------------------
# 服務配置
# -----------------------------------------------------------------------------
EXT_QUERY_HOST=0.0.0.0
EXT_QUERY_PORT=3005
